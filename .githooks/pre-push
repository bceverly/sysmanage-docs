#!/usr/bin/env bash
# Pre-push hook — runs `make lint` in the repo root and blocks the push
# if linting fails.  Designed to be installed via `core.hooksPath` (run
# `make install-hooks` once per clone), matching the sysmanage,
# sysmanage-agent, and sysmanage-professional-plus repos.
#
# For sysmanage-docs, `make lint` covers file-length, pylint, security
# (bandit), eslint, AND the i18n gates (i18n-validate key existence +
# translate-check for untranslated strings) — so this one hook enforces
# every local gate CI would.
#
# Behaviour:
#   * No Makefile, or no `lint:` target  → silent pass (so this hook
#     can be safely set globally without breaking other repos).
#   * `make lint` exit 0                 → push proceeds.
#   * `make lint` non-zero               → push blocked; error message
#     points at the failing tool and reminds about --no-verify for
#     genuine emergencies.
#
# Pre-push is the right moment for this — pre-commit runs on every
# `git commit` and would slow down the WIP-commit-often workflow,
# whereas pre-push runs once per push to remote.  CI-style coverage
# without the per-commit tax.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "${REPO_ROOT}" ]; then
    # Not in a git working tree (shouldn't happen for pre-push but
    # guard anyway).  Let git handle it.
    exit 0
fi

cd "${REPO_ROOT}"

# Skip the check unless the repo declares a `lint:` target.  Three
# practical reasons:
#   1. If someone sets this globally (`git config --global
#      core.hooksPath ~/.git-hooks`), other repos without a lint
#      target shouldn't be punished.
#   2. Lets us add the hook to a new repo by simply landing a
#      Makefile + lint target there — no per-repo config dance.
#   3. The check is fast (a grep) so the overhead is negligible.
if [ ! -f Makefile ] || ! grep -qE '^lint:[[:space:]]*' Makefile; then
    exit 0
fi

REPO_NAME="$(basename "${REPO_ROOT}")"
echo ""
echo "============================================================"
echo " Pre-push: running 'make lint' in ${REPO_NAME}..."
echo "============================================================"

# Git for Windows runs this hook inside MSYS bash, which puts sh.exe on PATH.
# GNU make then auto-detects that Unix shell and switches to Unix-shell mode,
# choking on this project's cmd.exe Windows recipes.  Forcing SHELL=cmd.exe on
# the make command line overrides that PATH-based detection, so the Windows
# branch runs exactly as it does from PowerShell.  Other platforms run make
# directly.
run_make_lint() {
    case "$(uname -s 2>/dev/null)" in
        MINGW*|MSYS*|CYGWIN*) make SHELL=cmd.exe lint ;;
        OpenBSD|FreeBSD|NetBSD) gmake lint ;;
        *)                    make lint ;;
    esac
}

if run_make_lint; then
    echo ""
    echo "============================================================"
    echo " Pre-push: lint clean — pushing."
    echo "============================================================"
    exit 0
fi

echo ""
echo "============================================================"
echo " Pre-push: 'make lint' FAILED in ${REPO_NAME}."
echo "============================================================"
echo ""
echo " Fix the errors above, then push again.  In a genuine"
echo " emergency you can bypass this hook with:"
echo ""
echo "     git push --no-verify"
echo ""
echo " (but the next make-lint run on CI will fail the same way,"
echo " so the bypass only buys you time, not a real fix.)"
echo ""
exit 1
