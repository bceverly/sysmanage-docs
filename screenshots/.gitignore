# Local config (contains passwords) — never commit
config.env

# License keys — never commit
*.license
*.key
*.pem
license/

# Vagrant VM state
.vagrant/
*.box

# Python tooling venv (seed.py is stdlib-only; fixture_agent.py needs websockets)
.venv/

# Seed-written fqdn->host-id map (consumed by capture.mjs for host-detail deep-links)
host_ids.json

# Generated by gen_seed_sql.py from fixtures.json (applied inside the VM)
seed_inventory.sql

# Node / Playwright
node_modules/
playwright-report/
test-results/

# Scratch screenshot output (final PNGs live in ../assets/images/ and ARE committed)
tmp/
*.tmp.png

# Self-signed demo license JWT (any tier)
license.jwt
