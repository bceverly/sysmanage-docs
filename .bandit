[bandit]
# Configuration file for the bandit security scanner (docs / screenshot repo).
# Mirrors the sibling sysmanage-agent baseline.
exclude_dirs = .venv,__pycache__,.git,.pytest_cache,node_modules,repo
# B101: assert statements (used in tests / one-shot scripts)
# B404: import subprocess (gen_seed_sql shells out to curl for the agent version)
# B608: "SQL injection" — false positive on gen_seed_sql.py, which GENERATES a
#       static seed_inventory.sql from trusted local fixtures.json via an
#       escaping q() helper; there is no runtime/user input in the SQL text.
#       (Same skip the sysmanage-agent repo uses.)
skips = B101,B404,B608
